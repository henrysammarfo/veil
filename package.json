{
  "name": "veil",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "vite dev",
    "dev:waitlist": "vite dev --mode waitlist --port 5173",
    "dev:judge": "vite dev --mode judge --port 5174",
    "build": "vite build",
    "build:waitlist": "vite build --mode waitlist",
    "build:production": "vite build --mode production",
    "build:judge": "vite build --mode production",
    "preflight": "npm run typecheck && npm run build:waitlist && npm run build:production",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:engine": "vitest run --config packages/execution-engine/vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "move:build": "cd packages/move/veil && sui move build --skip-fetch-latest-git-deps",
    "move:test": "cd packages/move/veil && sui move test --skip-fetch-latest-git-deps",
    "enclave": "npx tsx packages/veil-enclave/src/main.ts",
    "api": "npx tsx services/veil-api/src/index.ts",
    "keeper": "npx tsx services/keeper/src/index.ts",
    "smoke": "npx tsx scripts/smoke-test.ts",
    "smoke:live": "npx tsx scripts/e2e-live.ts",
    "judge:check": "powershell -File scripts/judge-check.ps1",
    "judge:terminal": "powershell -File scripts/judge-terminal.ps1",
    "e2e:live": "npm run smoke:live",
    "stress:execute": "npx tsx scripts/stress-execute.ts",
    "stress:keeper": "npx tsx scripts/stress-keeper.ts",
    "fuzz:digest": "npx tsx scripts/fuzz-execution-digest.ts",
    "test:live": "npm run smoke && npm run e2e:live",
    "setup:predict": "npx tsx scripts/setup-predict-live.ts",
    "fund:manager": "npx tsx scripts/fund-predict-manager.ts",
    "upgrade:move": "powershell -ExecutionPolicy Bypass -File scripts/upgrade-move.ps1",
    "install:sui-cli": "powershell -ExecutionPolicy Bypass -File scripts/install-sui-cli.ps1",
    "nitro:build": "bash scripts/azure-nitro-build.sh",
    "register:enclave": "npx tsx scripts/register-enclave.ts",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run test:engine && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mysten/dapp-kit": "^1.1.0",
    "@mysten/enoki": "^1.1.0",
    "@mysten/sui": "^2.18.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/router-plugin": "^1.167.28",
    "cbor": "^10.0.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.15.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "motion": "^12.40.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "aws-nitro-enclaves-nsm-node": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@lovable.dev/vite-tanstack-config": "^2.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "nitro": "3.0.260603-beta",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.9"
  }
}
