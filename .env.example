# Veil environment (copy to .env — never commit)

# Frontend (public / VITE_ only)
VITE_VEIL_API_URL=http://127.0.0.1:8787
VITE_VEIL_ENCLAVE_URL=http://127.0.0.1:8080
VITE_SUI_NETWORK=testnet
VITE_ENOKI_PUBLIC_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_VEIL_PACKAGE_ID=
# Public deploy — waitlist only; judges use access code at /auth
VITE_WAITLIST_ONLY=false
VITE_JUDGE_ACCESS_CODE=
VITE_VEIL_REGISTRY_ID=

# Backend (server-only — never prefix with VITE_)
ENOKI_SECRET_KEY=
VEIL_ENCLAVE_URL=http://127.0.0.1:8080
VEIL_API_PORT=8787
VEIL_ENCLAVE_PORT=8080
KEEPER_INTERVAL_MS=60000

# MemWal staging — https://staging.memwal.ai · docs.memwal.ai
MEMWAL_DELEGATE_KEY=
MEMWAL_ACCOUNT_ID=

# Sui testnet deployer + Predict PTBs (or use Enoki sponsorship)
SUI_PRIVATE_KEY=
SUI_RPC_URL=

# DeepBook Predict testnet (predict-testnet-4-16)
# DeepBook Predict testnet (run: npm run setup:predict)
PREDICT_MANAGER_ID=
PREDICT_ORACLE_ID=
PREDICT_ORACLE_EXPIRY=

# After `sui client publish`
VEIL_PACKAGE_ID=
VEIL_REGISTRY_ID=
VEIL_UPGRADE_CAP=0x1c1094ef5c9d58c30e4360aadc98bbac964aa4dbaa9388ba6699238f7ff4fcee
VEIL_ADMIN_CAP_ID=

# Real Nitro PCR (from AWS: curl EC2:8080/get_attestation) — optional on Azure demo
VEIL_PCR0=
VEIL_PCR1=
VEIL_PCR2=

# dUSDC capital policy (PredictManager ~1900 dUSDC testnet)
MANAGER_MINT_RESERVE_USDC=1400
MIN_EARN_SUPPLY_USDC=10
MAX_EARN_SUPPLY_USDC=75
KEEPER_DRIP_USDC=25
ORACLE_MAX_STALE_MS=30000
